{
  "name": "gateway-js",
  "version": "1.0.0",
  "description": "OpenIoTHub Gateway - TypeScript/Node.js version",
  "main": "dist/main.js",
  "bin": {
    "gateway-js": "dist/main.js"
  },
  "scripts": {
    "postinstall": "patch-package",
    "build": "tsc && cp -r src/proto dist/proto",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts"
  },
  "keywords": [
    "iot",
    "gateway",
    "openiothub",
    "nat"
  ],
  "author": "OpenIoTHub",
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "bonjour-service": "^1.3.0",
    "commander": "^13.1.0",
    "dockerode": "^4.0.4",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "kcpjs": "^1.0.10",
    "qrcode": "^1.5.4",
    "serialport": "^12.0.0",
    "ssh2": "^1.16.0",
    "systeminformation": "^5.25.11",
    "uuid": "^11.1.0",
    "ws": "^8.18.2",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.35",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.5",
    "@types/ssh2": "^1.15.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "patch-package": "^8.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
